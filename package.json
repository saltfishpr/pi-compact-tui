{
  "name": "pi-compact-tui",
  "version": "0.1.0",
  "description": "Pi extension bundle with compact, distraction-free editor and footer components for a focused coding experience",
  "keywords": [
    "pi-package"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/saltfishpr/pi-compact-tui.git"
  },
  "author": "saltfishpr",
  "license": "MIT",
  "homepage": "https://github.com/saltfishpr/pi-compact-tui#readme",
  "bugs": {
    "url": "https://github.com/saltfishpr/pi-compact-tui/issues"
  },
  "pi": {
    "extensions": [
      "./packages/pi-clear-command/index.ts",
      "./packages/pi-codex-stats/index.ts",
      "./packages/pi-compact-editor/index.ts",
      "./packages/pi-compact-footer/index.ts",
      "./packages/pi-deepseek-stats/index.ts",
      "./packages/pi-history/index.ts",
      "./packages/pi-provider-ark/index.ts",
      "./packages/pi-recap/index.ts",
      "./packages/pi-subagent/index.ts",
      "./packages/pi-trust-git/index.ts"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "defu": "^6.1.7",
    "ms": "^2.1.3",
    "write-file-atomic": "^8.0.0",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.80.8",
    "@earendil-works/pi-coding-agent": "^0.80.8",
    "@earendil-works/pi-tui": "^0.80.8",
    "@types/ms": "^2.1.0",
    "@types/node": "^26.0.1",
    "@types/write-file-atomic": "^4.0.3",
    "typescript": "^6.0.3"
  }
}
